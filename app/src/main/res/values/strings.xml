    <!-- Battery Optimization Guide -->
    <string name="xiaomi_guide">Xiaomi Phone Setup Steps:\n1. Settings > Battery and Power > App Smart Power Saving > This App > No Restrictions\n2. Settings > App Settings > App Management > This App > Autostart > Allow\n3. Settings > App Settings > Permission Management > Background Pop-up > Allow\n4. Long press app icon > App Info > Power Saving Policy > No Restrictions</string>
    <string name="oppo_guide">OPPO Phone Setup Steps:\n1. Phone Manager > Permissions and Privacy > Background Autostart Management > Allow This App\n2. Settings > Battery > App Power Consumption Management > This App > Allow Background Running\n3. Settings > App Management > This App > Power Protection > Allow Background Running</string>
    <string name="vivo_guide">vivo Phone Setup Steps:\n1. iManager > App Management > Autostart Management > Allow This App\n2. Settings > Battery > Background Power Consumption Management > This App > Allow High Background Power Consumption\n3. Settings > More Settings > Permission Management > Permissions > Autostart > Allow</string>
    <string name="huawei_guide">Huawei Phone Setup Steps:\n1. Phone Manager > App Startup Management > This App > Manual Management > Allow Autostart/Allow Background Activities\n2. Settings > Battery > App Startup Management > This App > Manual Management\n3. Settings > Apps > App Startup Management > Turn Off Auto Management > Allow Background Activities</string>
    <string name="general_guide">General Setup Steps:\n1. Settings > Battery/Power Saving > Battery Optimization > All Apps > Find This App > Don\'t Optimize\n2. Settings > App Management > This App > Battery > No Restrictions/Allow Background Running\n3. Ensure Autostart Permission is Enabled</string>
    
